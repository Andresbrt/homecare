# ==========================================
# Variables de Entorno para Homecare
# ==========================================
# Copia este archivo a .env y rellena los valores.
# NO subas el archivo .env a Git.

# --- Base de Datos (PostgreSQL Recomendado) ---
# URL de conexión JDBC. Ejemplo para PostgreSQL: jdbc:postgresql://localhost:5432/homecare
DB_URL=jdbc:postgresql://localhost:5432/homecare
DB_USERNAME=homecare_admin
DB_PASSWORD=tu_contraseña_segura
DB_DRIVER=org.postgresql.Driver
DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# --- Seguridad ---
# Secreto para firmar los tokens JWT. Debe ser una cadena larga y segura.
JWT_SECRET=secreto_muy_largo_y_dificil_de_adivinar_para_produccion
# Tiempo de expiración del token en milisegundos (ej. 86400000 para 24 horas)
JWT_EXPIRATION_MS=86400000

# --- Email (Configuración para Gmail) ---
# Es recomendable usar una "contraseña de aplicación" de Google si tienes 2FA.
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-contraseña-de-aplicacion

# --- Integraciones de Terceros ---
# Claves de la pasarela de pagos Wompi (Colombia)
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxx
# URL base de la API de Wompi (Sandbox por defecto)
WOMPI_API_BASE=https://sandbox.wompi.co/v1

# Clave de API de Google Maps para la aplicación móvil
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxx

# --- Configuración de la Aplicación ---
# Orígenes CORS permitidos (separados por comas) para el backend.
# Ej: http://localhost:3000,http://localhost:8081,https://tu-dominio.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# --- Configuración de IA (Opcional) ---
AI_ENABLED=true
AI_MODEL=gpt-4
AI_RATE_LIMIT_ENABLED=false
AI_RATE_LIMIT_MAX_REQUESTS=20
AI_RATE_LIMIT_WINDOW_SECONDS=60
