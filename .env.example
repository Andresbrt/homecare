# ============================================
# viclean - Variables de Entorno
# ============================================
# Copia este archivo a .env y configura tus valores

# === BASE DE DATOS ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viclean
DB_USER=viclean_user
DB_PASSWORD=viclean_pass

# === BACKEND ===
SERVER_PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400000

# === FRONTEND ===
REACT_APP_API_URL=http://localhost:8080/api

# === MOBILE ===
EXPO_PUBLIC_API_URL=http://localhost:8080/api
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_WEB_CLIENT_ID=your-web-client-id
APPLE_CLIENT_ID=your-apple-client-id

# === AI GLOBAL ===
AI_ENABLED=true
AI_MODEL=gpt-5.1-codex-max

# === SERVICIOS EXTERNOS ===
# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Wompi (Pagos Colombia)
WOMPI_PUBLIC_KEY=pub_test_xxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxx
WOMPI_EVENTS_SECRET=xxxxx

# === DOCKER ===
COMPOSE_PROJECT_NAME=viclean
